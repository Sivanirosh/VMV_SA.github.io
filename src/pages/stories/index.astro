---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryCard from '../../components/shared/StoryCard.astro';
import SectionHeader from '../../components/shared/SectionHeader.astro';
import { stories as storiesStrings } from '../../i18n/en';

const allStories = await getCollection('stories');
const sorted = allStories.sort((a, b) =>
  b.data.publishedDate.localeCompare(a.data.publishedDate)
);
---

<BaseLayout title={storiesStrings.meta.title} description={storiesStrings.meta.description}>
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeader
        heading={storiesStrings.heading}
        subheading={storiesStrings.subheading}
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map((story) => (
          <StoryCard
            slug={story.slug}
            name={story.data.name}
            age={story.data.age}
            location={story.data.location}
            coverImage={story.data.coverImage}
            quote={story.data.quote}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
