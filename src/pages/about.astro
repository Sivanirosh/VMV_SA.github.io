---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import DonateButton from '../components/shared/DonateButton.astro';
import { about, images } from '../i18n/en';
---

<BaseLayout title={about.meta.title} description={about.meta.description}>
  <!-- Hero -->
  <section class="relative py-24 bg-[var(--color-surface)] overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-6">
          {about.hero.heading}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">{about.hero.subheading}</p>
      </div>
      <div class="rounded-xl overflow-hidden aspect-[4/3]">
        <img src={images.aboutTeam} alt={images.aboutTeamAlt} class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4">
      <SectionHeader heading={about.mission.heading} />
      <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">{about.mission.body}</p>
    </div>
  </section>

  <!-- Origin story -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4">
      <SectionHeader heading={about.origin.heading} />
      <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">{about.origin.body}</p>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4">
      <SectionHeader heading={about.team.heading} />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {about.team.members.map((member) => (
          <div class="flex gap-5 items-start p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
            <img
              src={member.image}
              alt={member.imageAlt}
              class="w-20 h-20 rounded-full object-cover shrink-0"
            />
            <div>
              <p class="font-heading font-bold text-lg text-[var(--color-text)]">{member.name}</p>
              <p class="text-sm text-[var(--color-primary)] font-semibold mb-2">{member.role}</p>
              <p class="text-sm text-[var(--color-text-muted)]">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Financials -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4">
      <SectionHeader heading={about.financials.heading} />
      <p class="text-[var(--color-text-muted)] mb-6">{about.financials.body}</p>
      <a
        href={about.financials.linkHref}
        class="inline-flex items-center gap-2 text-[var(--color-primary)] font-semibold hover:underline"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        </svg>
        {about.financials.linkLabel}
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold text-[var(--color-text)] mb-4">Ready to help?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">Your contribution directly builds classrooms for children in rural Sri Lanka.</p>
      <DonateButton size="lg" />
    </div>
  </section>
</BaseLayout>
