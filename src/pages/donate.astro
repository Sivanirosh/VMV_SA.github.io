---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import { donate, images } from '../i18n/en';
---

<BaseLayout title={donate.meta.title} description={donate.meta.description}>
  <!-- Hero -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-4">
        {donate.hero.heading}
      </h1>
      <p class="text-lg text-[var(--color-text-muted)]">{donate.hero.subheading}</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-16">

      <!-- Donation form (static) -->
      <div>
        <SectionHeader heading={donate.form.amountHeading} />

        <!-- Currency selector -->
        <div class="flex gap-2 mb-6">
          {donate.form.currencies.map((currency) => (
            <button
              disabled
              class={`px-4 py-2 rounded-md text-sm font-semibold border transition-colors cursor-not-allowed ${
                currency === donate.form.defaultCurrency
                  ? 'bg-[var(--color-primary)] text-white border-[var(--color-primary)]'
                  : 'border-[var(--color-border)] text-[var(--color-text-muted)]'
              }`}
            >
              {currency}
            </button>
          ))}
        </div>

        <!-- Frequency toggle -->
        <div class="flex gap-2 mb-6">
          {[donate.form.frequencyOnce, donate.form.frequencyMonthly].map((label, i) => (
            <button
              disabled
              class={`flex-1 py-3 rounded-md text-sm font-semibold border cursor-not-allowed transition-colors ${
                i === 0
                  ? 'bg-[var(--color-text)] text-white border-[var(--color-text)]'
                  : 'border-[var(--color-border)] text-[var(--color-text-muted)]'
              }`}
            >
              {label}
            </button>
          ))}
        </div>

        <!-- Amount tiers -->
        <div class="grid grid-cols-2 gap-3 mb-4">
          {donate.form.tiers.map((tier) => (
            <button
              disabled
              class="py-4 rounded-xl border-2 border-[var(--color-border)] text-[var(--color-text)] font-semibold text-lg hover:border-[var(--color-primary)] cursor-not-allowed transition-colors"
            >
              {donate.form.defaultCurrency} {tier}
            </button>
          ))}
        </div>

        <!-- Custom amount -->
        <div class="mb-6">
          <input
            type="number"
            disabled
            placeholder={donate.form.customPlaceholder}
            class="w-full px-4 py-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none"
          />
        </div>

        <!-- Submit -->
        <button
          disabled
          class="w-full py-4 rounded-md font-semibold text-white bg-[var(--color-primary)] opacity-60 cursor-not-allowed text-lg"
        >
          {donate.form.submitLabel}
        </button>
        <p class="mt-3 text-xs text-center text-[var(--color-text-muted)]">{donate.form.disclaimer}</p>

        <!-- Tax receipt note -->
        <div class="mt-8 p-4 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)]">
          <p class="text-sm font-semibold text-[var(--color-text)] mb-1">{donate.taxReceipt.heading}</p>
          <p class="text-sm text-[var(--color-text-muted)]">{donate.taxReceipt.body}</p>
        </div>
      </div>

      <!-- Alternative payment methods -->
      <div class="space-y-8">

        <!-- Bank transfer -->
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
          <h3 class="font-heading text-xl font-bold text-[var(--color-text)] mb-4">{donate.wire.heading}</h3>
          <dl class="space-y-3 text-sm">
            <div class="flex flex-col">
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wide font-semibold">Beneficiary</dt>
              <dd class="font-medium text-[var(--color-text)]">{donate.wire.beneficiary}</dd>
            </div>
            <div class="flex flex-col">
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wide font-semibold">IBAN</dt>
              <dd class="font-mono font-medium text-[var(--color-text)]">{donate.wire.iban}</dd>
            </div>
            <div class="flex flex-col">
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wide font-semibold">Bank</dt>
              <dd class="font-medium text-[var(--color-text)]">{donate.wire.bank}</dd>
            </div>
          </dl>
          <p class="mt-4 text-xs text-[var(--color-text-muted)] leading-relaxed border-t border-[var(--color-border)] pt-4">
            {donate.wire.reference}
          </p>
        </div>

        <!-- Twint -->
        <div class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
          <h3 class="font-heading text-xl font-bold text-[var(--color-text)] mb-2">{donate.twint.heading}</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-4">{donate.twint.instruction}</p>
          <div class="flex justify-center">
            <img
              src={images.twintQr}
              alt={images.twintQrAlt}
              class="w-40 h-40"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
