---
import { footer, nav, siteName } from '../../i18n/en';
import { url } from '../../utils/url';
---

<footer class="bg-[var(--color-surface)] border-t border-[var(--color-border)] mt-20">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="font-heading text-lg font-bold text-[var(--color-text)] mb-2">{siteName}</p>
        <p class="text-sm text-[var(--color-text-muted)]">{footer.tagline}</p>
      </div>

      <!-- Nav links -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Navigate</p>
        <ul class="flex flex-col gap-2 list-none m-0 p-0">
          <li><a href={url('/')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{nav.home}</a></li>
          <li><a href={url('/about')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{nav.about}</a></li>
          <li><a href={url('/projects')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{nav.projects}</a></li>
          <li><a href={url('/stories')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{nav.stories}</a></li>
          <li><a href={url('/volunteer')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{nav.volunteer}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Legal</p>
        <ul class="flex flex-col gap-2 list-none m-0 p-0">
          <li><a href="#" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{footer.links.privacy}</a></li>
          <li><a href={url('/contact')} class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{footer.links.contact}</a></li>
          <li><a href="#" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">{footer.links.financials}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border)] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[var(--color-text-muted)]">{footer.copyright}</p>
      <!-- Social icons placeholder -->
      <div class="flex gap-4">
        <a href="#" aria-label="Facebook" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
