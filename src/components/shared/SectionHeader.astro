---
interface Props {
  heading: string;
  subheading?: string;
  centered?: boolean;
}

const { heading, subheading, centered = false } = Astro.props;
---

<div class={`mb-10 ${centered ? 'text-center' : ''}`}>
  <h2 class="font-heading text-3xl md:text-4xl font-bold text-[var(--color-text)] leading-tight">
    {heading}
  </h2>
  {subheading && (
    <p class="mt-3 text-lg text-[var(--color-text-muted)] max-w-2xl leading-relaxed">
      {subheading}
    </p>
  )}
</div>
