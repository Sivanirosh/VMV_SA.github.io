---
import { contact } from '../../i18n/en';

const { fields, submit } = contact.form;
---

<form action="#" class="space-y-5">
  <div>
    <label class="block text-sm font-semibold text-[var(--color-text)] mb-1" for="contact-org">
      {fields.organisation}
    </label>
    <input
      id="contact-org"
      type="text"
      disabled
      placeholder="In Progress…"
      class="w-full px-4 py-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
    />
  </div>
  <div>
    <label class="block text-sm font-semibold text-[var(--color-text)] mb-1" for="contact-name">
      {fields.name}
    </label>
    <input
      id="contact-name"
      type="text"
      disabled
      placeholder="In Progress…"
      class="w-full px-4 py-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
    />
  </div>
  <div>
    <label class="block text-sm font-semibold text-[var(--color-text)] mb-1" for="contact-email">
      {fields.email}
    </label>
    <input
      id="contact-email"
      type="email"
      disabled
      placeholder="In Progress…"
      class="w-full px-4 py-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
    />
  </div>
  <div>
    <label class="block text-sm font-semibold text-[var(--color-text)] mb-1" for="contact-message">
      {fields.message}
    </label>
    <textarea
      id="contact-message"
      rows="5"
      disabled
      placeholder="In Progress…"
      class="w-full px-4 py-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)] placeholder-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] resize-none"
    ></textarea>
  </div>
  <button
    type="submit"
    disabled
    class="w-full py-3 px-6 rounded-md font-semibold text-white bg-[var(--color-primary)] opacity-60 cursor-not-allowed"
  >
    {submit}
  </button>
</form>
