---
import { home } from '../../i18n/en';
---

<section class="py-20 bg-[var(--color-primary)]">
  <div class="max-w-2xl mx-auto px-4 text-center text-white">
    <h2 class="font-heading text-3xl font-bold mb-3">{home.newsletter.heading}</h2>
    <p class="text-white/80 mb-8">{home.newsletter.subheading}</p>
    <form action="#" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        placeholder={home.newsletter.placeholder}
        class="flex-1 px-4 py-3 rounded-md text-[var(--color-text)] bg-white placeholder-[var(--color-text-muted)] border-0 focus:outline-none focus:ring-2 focus:ring-white/50"
        disabled
      />
      <button
        type="submit"
        disabled
        class="px-6 py-3 rounded-md font-semibold bg-[var(--color-primary-dark)] text-white hover:bg-[var(--color-text)] transition-colors opacity-80 cursor-not-allowed"
      >
        {home.newsletter.cta}
      </button>
    </form>
    <p class="mt-4 text-xs text-white/60">{home.newsletter.disclaimer}</p>
  </div>
</section>
