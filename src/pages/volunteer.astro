---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import VolunteerForm from '../components/forms/VolunteerForm.astro';
import { volunteer } from '../i18n/en';
---

<BaseLayout title={volunteer.meta.title} description={volunteer.meta.description}>
  <!-- Hero -->
  <section class="py-20 bg-[var(--color-surface)]">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-4">
        {volunteer.hero.heading}
      </h1>
      <p class="text-lg text-[var(--color-text-muted)]">{volunteer.hero.subheading}</p>
    </div>
  </section>

  <!-- Info + Form -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-16">
      <div>
        <SectionHeader heading={volunteer.info.heading} />
        <p class="text-[var(--color-text-muted)] leading-relaxed">{volunteer.info.body}</p>
      </div>
      <div>
        <h2 class="font-heading text-2xl font-bold text-[var(--color-text)] mb-6">
          {volunteer.form.heading}
        </h2>
        <VolunteerForm />
      </div>
    </div>
  </section>
</BaseLayout>
